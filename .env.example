# ── BillyBot Telegram Bot Environment Variables ──

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Your BillyBot backend URL (Railway)
BILLYBOT_API_URL=https://your-backend.up.railway.app

# Shared secret — must match BOT_SECRET in your backend .env
BOT_SECRET=REPLACE_WITH_SAME_SECRET_AS_BACKEND

# Your frontend URL (for connect links sent to users)
FRONTEND_URL=https://your-site.netlify.app

# Your bot's Telegram username (without @) — used for connect links
BILLYBOT_BOT=YourBotUsername_bot
